generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
}

// ─── KUNDE ────────────────────────────────────────────────────────────────────

model Kunde {
  id               Int      @id @default(autoincrement())
  name             String
  firma            String?
  kategorie        String   @default("Sonstige")
  verantwortlicher String?  // frei gewählt aus Mitarbeiterliste
  betriebsnummer   String?  // z.B. aus AFIG/InVeKoS
  flaeche          Float?   // ha, manuell erfasst
  strasse          String?
  plz              String?
  ort              String?
  land             String   @default("Deutschland")
  lat              Float?
  lng              Float?
  notizen          String?
  tags             String   @default("[]")  // JSON array of tag strings
  aktiv            Boolean  @default(true)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  kontakte         KundeKontakt[]
  bedarfe          KundeBedarf[]
  artikelPreise    KundeArtikelPreis[]
  lieferungen      Lieferung[]
  mengenrabatte    Mengenrabatt[]
  sammelrechnungen Sammelrechnung[]
  aktivitaeten     KundeAktivitaet[]
  antragDaten      AntragEmpfaenger[]
  kundeNotizen     KundeNotiz[]
  angebote         Angebot[]
  schlaegte        KundeSchlag[]
  aufgaben         Aufgabe[]
  driveOrdnerId    String?  // Google Drive Folder ID
}

model KundeKontakt {
  id      Int     @id @default(autoincrement())
  kundeId Int
  typ     String  // telefon | mobil | email | fax
  wert    String
  label   String? // z.B. "Büro", "Herr Müller"

  kunde Kunde @relation(fields: [kundeId], references: [id], onDelete: Cascade)
}

// ─── NOTIZEN ─────────────────────────────────────────────────────────────────

model KundeNotiz {
  id       Int      @id @default(autoincrement())
  kundeId  Int
  kunde    Kunde    @relation(fields: [kundeId], references: [id], onDelete: Cascade)
  text     String
  thema    String?  // e.g. "Wichtig", "Offener Punkt", "Erledigt", "Info"
  erstellt DateTime @default(now())

  @@index([kundeId])
}

// ─── CRM ──────────────────────────────────────────────────────────────────────

model KundeAktivitaet {
  id        Int      @id @default(autoincrement())
  kundeId   Int
  typ       String   // besuch | anruf | email | notiz | aufgabe
  betreff   String
  inhalt    String?
  datum     DateTime @default(now())
  erledigt  Boolean  @default(false)
  faelligAm DateTime?
  createdAt DateTime @default(now())

  kunde Kunde @relation(fields: [kundeId], references: [id], onDelete: Cascade)

  @@index([kundeId])
  @@index([datum])
  @@index([faelligAm])
}

// ─── LIEFERANT ────────────────────────────────────────────────────────────────

model Lieferant {
  id              Int      @id @default(autoincrement())
  name            String
  ansprechpartner String?
  email           String?
  telefon         String?
  strasse         String?
  plz             String?
  ort             String?
  notizen         String?
  aktiv           Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  artikelZuordnungen ArtikelLieferant[]
  wareneingaenge     Wareneingang[]
}

// ─── ARTIKEL ──────────────────────────────────────────────────────────────────

model Artikel {
  id               Int      @id @default(autoincrement())
  artikelnummer    String   @unique
  name             String
  kategorie        String   // Futter | Duenger | Saatgut
  einheit          String   @default("kg") // kg | t | Sack | Liter | Stück
  beschreibung     String?
  standardpreis    Float    @default(0)
  mwstSatz         Float    @default(19) // 0 | 7 | 19
  mindestbestand   Float    @default(0)
  aktuellerBestand Float    @default(0)
  aktiv            Boolean  @default(true)
  lagerort         String?  // optional: storage location label
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  lieferanten      ArtikelLieferant[]
  kundePreise      KundeArtikelPreis[]
  preisHistorie    ArtikelPreisHistorie[]
  bedarfe          KundeBedarf[]
  lieferpositionen Lieferposition[]
  angebotPositionen AngebotPosition[]
  lagerbewegungen  Lagerbewegung[]
  wareineingangPos WareineingangPosition[]
  dokumente        ArtikelDokument[]
  mengenrabatte    Mengenrabatt[]
  inventurPositionen InventurPosition[]
  driveOrdnerId    String?  // Google Drive Folder ID
}

model ArtikelDokument {
  id          Int      @id @default(autoincrement())
  artikelId   Int
  name        String
  dateiname   String   // original filename
  pfad        String   // stored path under /uploads/artikel/
  typ         String?  // MIME type
  groesse     Int?     // bytes
  notiz       String?
  createdAt   DateTime @default(now())

  artikel Artikel @relation(fields: [artikelId], references: [id], onDelete: Cascade)
}

model ArtikelLieferant {
  id                  Int      @id @default(autoincrement())
  artikelId           Int
  lieferantId         Int
  lieferantenArtNr    String?
  einkaufspreis       Float    @default(0)
  mindestbestellmenge Float    @default(0)
  lieferzeitTage      Int      @default(3)
  bevorzugt           Boolean  @default(false)
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  artikel   Artikel   @relation(fields: [artikelId], references: [id], onDelete: Cascade)
  lieferant Lieferant @relation(fields: [lieferantId], references: [id], onDelete: Cascade)

  @@unique([artikelId, lieferantId])
}

// Preishistorie: jede Änderung am Standardpreis wird versioniert
model ArtikelPreisHistorie {
  id          Int      @id @default(autoincrement())
  artikelId   Int
  alterPreis  Float
  neuerPreis  Float
  geaendertAm DateTime @default(now())
  notiz       String?

  artikel Artikel @relation(fields: [artikelId], references: [id], onDelete: Cascade)
}

// ─── PREISE & KONDITIONEN ─────────────────────────────────────────────────────

model KundeArtikelPreis {
  id        Int      @id @default(autoincrement())
  kundeId   Int
  artikelId Int
  preis     Float
  rabatt    Float    @default(0) // Prozent
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  kunde   Kunde   @relation(fields: [kundeId], references: [id], onDelete: Cascade)
  artikel Artikel @relation(fields: [artikelId], references: [id], onDelete: Cascade)

  @@unique([kundeId, artikelId])
}

// ─── BEDARF (wiederkehrende Lieferungen) ──────────────────────────────────────

model KundeBedarf {
  id            Int      @id @default(autoincrement())
  kundeId       Int
  artikelId     Int
  menge         Float
  intervallTage Int      @default(30)
  notiz         String?
  aktiv         Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  kunde   Kunde   @relation(fields: [kundeId], references: [id], onDelete: Cascade)
  artikel Artikel @relation(fields: [artikelId], references: [id], onDelete: Cascade)

  @@unique([kundeId, artikelId])
}

// ─── LIEFERUNG ────────────────────────────────────────────────────────────────

model Lieferung {
  id               Int      @id @default(autoincrement())
  kundeId          Int
  datum            DateTime @default(now())
  status           String   @default("geplant") // geplant | geliefert | storniert
  stornoBegründung String?
  notiz            String?
  rechnungNr       String?  // gesetzt wenn Rechnung erstellt wurde
  rechnungDatum    DateTime?
  bezahltAm        DateTime?
  zahlungsziel     Int?      @default(30)  // Tage
  wiederkehrend    Boolean  @default(false) // wurde automatisch angelegt
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  kunde             Kunde            @relation(fields: [kundeId], references: [id])
  positionen        Lieferposition[]
  lagerbewegungen   Lagerbewegung[]
  sammelrechnung    Sammelrechnung?  @relation(fields: [sammelrechnungId], references: [id])
  sammelrechnungId  Int?

  @@index([kundeId])
  @@index([status])
  @@index([datum])
}

model Lieferposition {
  id            Int     @id @default(autoincrement())
  lieferungId   Int
  artikelId     Int
  menge         Float
  verkaufspreis Float
  einkaufspreis Float   @default(0)
  chargeNr      String? // Chargen-/Losnummer (gesetzlich für Saatgut)
  rabattProzent Float   @default(0) // Mengenrabatt der angewendet wurde

  lieferung Lieferung @relation(fields: [lieferungId], references: [id], onDelete: Cascade)
  artikel   Artikel   @relation(fields: [artikelId], references: [id])
}

// ─── WARENEINGANG ─────────────────────────────────────────────────────────────

model Wareneingang {
  id          Int      @id @default(autoincrement())
  lieferantId Int
  datum       DateTime @default(now())
  notiz       String?
  createdAt   DateTime @default(now())

  lieferant       Lieferant              @relation(fields: [lieferantId], references: [id])
  positionen      WareineingangPosition[]
  lagerbewegungen Lagerbewegung[]
}

model WareineingangPosition {
  id             Int   @id @default(autoincrement())
  wareneingangId Int
  artikelId      Int
  menge          Float
  einkaufspreis  Float

  wareneingang Wareneingang @relation(fields: [wareneingangId], references: [id], onDelete: Cascade)
  artikel      Artikel      @relation(fields: [artikelId], references: [id])
}

// ─── LAGERBEWEGUNG ────────────────────────────────────────────────────────────

model Lagerbewegung {
  id             Int      @id @default(autoincrement())
  artikelId      Int
  typ            String   // eingang | ausgang | korrektur | UMBUCHUNG
  menge          Float    // positiv = Zugang, negativ = Abgang
  bestandNach    Float
  datum          DateTime @default(now())
  notiz          String?
  lieferungId    Int?
  wareneingangId Int?
  lagerortVon    String?  // source location (for Umbuchung)
  lagerortNach   String?  // target location (for Umbuchung)

  artikel      Artikel       @relation(fields: [artikelId], references: [id])
  lieferung    Lieferung?    @relation(fields: [lieferungId], references: [id])
  wareneingang Wareneingang? @relation(fields: [wareneingangId], references: [id])
}

// ─── MENGENRABATTE ────────────────────────────────────────────────────────────

model Mengenrabatt {
  id            Int      @id @default(autoincrement())
  kundeId       Int?     // null = gilt für alle Kunden
  artikelId     Int?     // null = gilt für alle Artikel der Kategorie
  kategorie     String?  // alternativ zu artikelId: gilt für ganze Kategorie
  vonMenge      Float    // ab dieser Menge gilt der Rabatt
  rabattProzent Float    // Rabatt in %
  aktiv         Boolean  @default(true)
  createdAt     DateTime @default(now())

  kunde   Kunde?   @relation(fields: [kundeId], references: [id], onDelete: Cascade)
  artikel Artikel? @relation(fields: [artikelId], references: [id], onDelete: Cascade)
}

// ─── SAMMELRECHNUNG ───────────────────────────────────────────────────────────

model Sammelrechnung {
  id           Int      @id @default(autoincrement())
  kundeId      Int
  rechnungNr   String?
  rechnungDatum DateTime?
  bezahltAm   DateTime?
  zahlungsziel Int      @default(30)
  notiz        String?
  createdAt    DateTime @default(now())

  kunde       Kunde       @relation(fields: [kundeId], references: [id])
  lieferungen Lieferung[]
}

// ─── INVENTUR ────────────────────────────────────────────────────────────────

model Inventur {
  id          Int                @id @default(autoincrement())
  datum       DateTime           @default(now())
  status      String             @default("OFFEN") // OFFEN | ABGESCHLOSSEN
  bezeichnung String?
  positionen  InventurPosition[]

  @@index([status])
}

model InventurPosition {
  id          Int      @id @default(autoincrement())
  inventurId  Int
  inventur    Inventur @relation(fields: [inventurId], references: [id], onDelete: Cascade)
  artikelId   Int
  artikel     Artikel  @relation(fields: [artikelId], references: [id])
  sollBestand Float    // snapshot of bestand at time of inventur
  istBestand  Float?   // counted value
  differenz   Float?   // computed: istBestand - sollBestand
  bemerkung   String?

  @@index([inventurId])
  @@index([artikelId])
}

// ─── SYSTEM: Rechnungsnummer-Zähler ──────────────────────────────────────────

model Einstellung {
  key   String @id
  value String
}

// ─── OPEN DATA: Marktpreise (Eurostat) ───────────────────────────────────────

model MarktpreisCache {
  id          Int      @id @default(autoincrement())
  dataset     String   // "apri_pi15_inq" (quartalsweise) oder "apri_pi15_ina" (jährlich)
  produktCode String   // z.B. "206000" (Futtermittel)
  produktName String   // z.B. "Futtermittel"
  zeitraum    String   // z.B. "2024-Q3" oder "2024"
  indexWert   Float    // Indexwert (2015 = 100)
  einheit     String   @default("I15")
  land        String   @default("DE")
  abgerufenAm DateTime @default(now())
  createdAt   DateTime @default(now())

  @@unique([dataset, produktCode, zeitraum, land])
}

// ─── OPEN DATA: Agrarflächen (Overpass / OSM) ────────────────────────────────

model AgrarflaechenCache {
  id           Int      @id @default(autoincrement())
  lat          Float
  lng          Float
  radius       Int      // Meter
  flaecheHa    Float    // Gesamtfläche in Hektar
  polygonCount Int      // Anzahl Polygone
  geojson      String   // GeoJSON FeatureCollection
  abgerufenAm  DateTime @default(now())
  createdAt    DateTime @default(now())

  @@unique([lat, lng, radius])
}

// ─── AGRARANTRÄGE (AFIG / agrarzahlungen.de) ──────────────────────────────────

model AntragEmpfaenger {
  id                        Int      @id @default(autoincrement())
  haushaltsjahr             Int
  name                      String   // Name des Begünstigten
  plz                       String?
  gemeinde                  String?
  land                      String?
  steuerNr                  String?  // Steuerliches Identifikationsmerkmal
  egflGesamt                Float    @default(0)  // EGFL-Gesamtbetrag für diesen Begünstigten (Spalte 12)
  elerGesamt                Float    @default(0)  // ELER-Gesamtbetrag EU-Mittel (Spalte 14)
  nationalKofiGesamt        Float    @default(0)  // National kofinanzierter Gesamtbetrag (Spalte 16)
  elerUndKofiGesamt         Float    @default(0)  // ELER + national Kofi (Spalte 17)
  gesamtBetrag              Float    @default(0)  // EU-Betrag + Kofi gesamt (Spalte 18)
  massnahmen                String?  // JSON: [{code, ziel, egfl, eler, nationalKofi, anfang, ende}]
  mutterunternehmen         String?
  importiertAm              DateTime @default(now())

  kundeId           Int?
  kunde             Kunde?   @relation(fields: [kundeId], references: [id], onDelete: SetNull)

  @@index([name])
  @@index([plz])
  @@index([gemeinde])
  @@index([haushaltsjahr])
  @@index([kundeId])
}

// ─── AUFGABEN / TODO ──────────────────────────────────────────────────────────

model Aufgabe {
  id           Int       @id @default(autoincrement())
  betreff      String
  beschreibung String?
  faelligAm    DateTime?
  erledigt     Boolean   @default(false)
  erledigtAm   DateTime?
  prioritaet   String    @default("normal")  // niedrig | normal | hoch | kritisch
  tags         String    @default("[]")       // JSON array of strings
  typ          String    @default("aufgabe")  // aufgabe | anruf | besuch | email
  kundeId      Int?
  erstellt     DateTime  @default(now())
  aktualisiert DateTime  @updatedAt

  kunde        Kunde?    @relation(fields: [kundeId], references: [id], onDelete: SetNull)

  @@index([kundeId])
  @@index([erledigt])
  @@index([faelligAm])
}

// ─── ANGEBOTSWESEN ────────────────────────────────────────────────────────────

model Angebot {
  id          Int      @id @default(autoincrement())
  nummer      String   @unique          // z.B. AN-2026-0001
  datum       DateTime @default(now())
  gueltigBis  DateTime?
  status      String   @default("OFFEN") // OFFEN | ANGENOMMEN | ABGELEHNT | ABGELAUFEN
  kundeId     Int
  notiz       String?
  erstellt    DateTime @default(now())
  aktualisiert DateTime @updatedAt

  kunde       Kunde            @relation(fields: [kundeId], references: [id], onDelete: Cascade)
  positionen  AngebotPosition[]

  @@index([kundeId])
  @@index([status])
  @@index([datum])
}

model AngebotPosition {
  id         Int    @id @default(autoincrement())
  angebotId  Int
  artikelId  Int
  menge      Float
  preis      Float  // Angebotspreis (netto)
  rabatt     Float  @default(0)
  einheit    String @default("kg")
  notiz      String?

  angebot    Angebot @relation(fields: [angebotId], references: [id], onDelete: Cascade)
  artikel    Artikel @relation(fields: [artikelId], references: [id])
}

// ─── SCHLAGKARTEI ─────────────────────────────────────────────────────────────

model KundeSchlag {
  id         Int      @id @default(autoincrement())
  kundeId    Int
  name       String                          // Schlagname / Feldname
  flaeche    Float                           // ha
  fruchtart  String?                         // Weizen, Raps, Gerste …
  sorte      String?                         // Sortenname
  vorfrucht  String?
  aussaatJahr Int?
  aussaatMenge Float?                        // kg/ha
  notiz      String?
  erstellt   DateTime @default(now())

  kunde      Kunde @relation(fields: [kundeId], references: [id], onDelete: Cascade)

  @@index([kundeId])
}
