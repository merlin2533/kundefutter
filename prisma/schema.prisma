generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
}

// ─── KUNDE ────────────────────────────────────────────────────────────────────

model Kunde {
  id               Int      @id @default(autoincrement())
  name             String
  firma            String?
  kategorie        String   @default("Sonstige")
  verantwortlicher String?  // frei gewählt aus Mitarbeiterliste
  betriebsnummer   String?  // z.B. aus AFIG/InVeKoS
  flaeche          Float?   // ha, manuell erfasst
  strasse          String?
  plz              String?
  ort              String?
  land             String   @default("Deutschland")
  lat              Float?
  lng              Float?
  notizen          String?
  tags             String   @default("[]")  // JSON array of tag strings
  ustIdNr          String?  // USt-Identifikationsnummer (für ZUGFeRD E-Rechnung)
  aktiv            Boolean  @default(true)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  kontakte         KundeKontakt[]
  bedarfe          KundeBedarf[]
  artikelPreise    KundeArtikelPreis[]
  lieferungen      Lieferung[]
  mengenrabatte    Mengenrabatt[]
  sammelrechnungen Sammelrechnung[]
  aktivitaeten     KundeAktivitaet[]
  antragDaten      AntragEmpfaenger[]
  kundeNotizen     KundeNotiz[]
  angebote         Angebot[]
  schlaegte        KundeSchlag[]
  aufgaben         Aufgabe[]
  gutschriften     Gutschrift[]
  anlieferungen    Anlieferung[]
  bestellpositionen Bestellposition[]
  driveOrdnerId    String?  // Google Drive Folder ID
  kreditlimit          Float?    // max. offener Betrag in €
  sachkundeNr          String?   // PSM-Sachkundenummer §9 PflSchG
  sachkundeGueltigBis  DateTime? // Ablaufdatum Sachkundenachweis

  psmAusbringungen     PsmAusbringung[]
  kontrakte            Kontrakt[]
  reklamationen        Reklamation[]
  sprengstoffErklaerungen KundeSprengstoffErklaerung[]
  sachkundenachweise   Sachkundenachweis[]
  sortenversuche       Sortenversuch[]
  vorbestellungen      Vorbestellung[]
  tiere                KundeTier[]
  rationsberechnungen  Rationsberechnung[]

  // ─── VVVO (Vieh-Verkehrs-Verordnung / HIT) ────────────────────────────────
  vvvoNr               String?   // 12-stellige Betriebsnummer DE + 2 Land + 8 Betrieb (z.B. DE 03 1234 5678)

  portalZugang         KundePortalZugang?
  anbauplaene          Anbauplan[]
  zertifizierungen     Zertifizierung[]

  @@index([aktiv])
  @@index([kategorie])
  @@index([name])
}

model KundeKontakt {
  id       Int     @id @default(autoincrement())
  kundeId  Int
  typ      String  // telefon | mobil | email | fax
  wert     String
  label    String? // z.B. "Büro"
  vorname  String?
  nachname String?

  kunde Kunde @relation(fields: [kundeId], references: [id], onDelete: Cascade)
}

// ─── NOTIZEN ─────────────────────────────────────────────────────────────────

model KundeNotiz {
  id       Int      @id @default(autoincrement())
  kundeId  Int
  kunde    Kunde    @relation(fields: [kundeId], references: [id], onDelete: Cascade)
  text     String
  thema    String?  // e.g. "Wichtig", "Offener Punkt", "Erledigt", "Info"
  erstellt DateTime @default(now())

  @@index([kundeId])
}

// ─── SPRENGSTOFFVORLÄUFER-ERKLÄRUNG (EU-VO 2019/1148) ─────────────────────────

model KundeSprengstoffErklaerung {
  id           Int      @id @default(autoincrement())
  kundeId      Int
  jahr         Int      // Kalenderjahr der Erklärung
  datum        DateTime // Datum der Unterzeichnung
  dokumentPfad String?  // optionaler Datei-Upload (unter /uploads/erklaerungen/)
  notiz        String?
  createdAt    DateTime @default(now())

  kunde Kunde @relation(fields: [kundeId], references: [id], onDelete: Cascade)

  @@unique([kundeId, jahr])
  @@index([kundeId])
}

// ─── CRM ──────────────────────────────────────────────────────────────────────

model KundeAktivitaet {
  id        Int      @id @default(autoincrement())
  kundeId   Int
  typ       String   // besuch | anruf | email | notiz | aufgabe
  betreff   String
  inhalt    String?
  datum     DateTime @default(now())
  erledigt  Boolean  @default(false)
  faelligAm DateTime?
  createdAt DateTime @default(now())

  kunde Kunde @relation(fields: [kundeId], references: [id], onDelete: Cascade)

  @@index([kundeId])
  @@index([datum])
  @@index([faelligAm])
  @@index([erledigt])
}

// ─── LIEFERANT ────────────────────────────────────────────────────────────────

model Lieferant {
  id              Int      @id @default(autoincrement())
  name            String
  ansprechpartner String?
  email           String?
  telefon         String?
  strasse         String?
  plz             String?
  ort             String?
  notizen         String?
  aktiv           Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  artikelZuordnungen ArtikelLieferant[]
  wareneingaenge     Wareneingang[]
  bestellpositionen  Bestellposition[]
  ausgaben           Ausgabe[]
  bestellungen       Bestellung[]
  eingangsRechnungen EingangsRechnung[]
  streckenLieferungen Lieferung[] @relation("StreckenLieferant")
}

// ─── ARTIKEL ──────────────────────────────────────────────────────────────────

model Artikel {
  id               Int      @id @default(autoincrement())
  artikelnummer    String   @unique
  name             String
  kategorie        String   // Futter | Duenger | Saatgut
  unterkategorie   String?  // optional Subkategorie, z.B. Saatgut → Mais|Raps|Getreide|…
  einheit          String   @default("kg") // kg | t | Sack | Liter | Stück
  beschreibung     String?
  standardpreis    Float    @default(0)
  preisStand       DateTime? // Datum, von wann der aktuelle Preis ist
  mwstSatz         Float    @default(19) // 0 | 7 | 19
  mindestbestand   Float    @default(0)
  aktuellerBestand Float    @default(0)
  aktiv                  Boolean  @default(true)
  lagerort               String?  // optional: storage location label
  liefergroesse          String?  // Liefergröße Freitext (z.B. "25 kg Sack", "Big Bag 600 kg")
  chargePflicht          Boolean  @default(false) // Chargennummer beim Warenausgang Pflicht
  sprengstoffvorlaeufer  Boolean  @default(false) // EU-VO 2019/1148: eingeschränkt abgebbar
  ghsKlassen             String?  // JSON array: ["GHS05","GHS07"] — Gefahrenpiktogramme
  hSaetze                String?  // JSON: ["H302","H318"] — Hazard statements
  pSaetze                String?  // JSON: ["P260","P280"] — Precautionary statements
  signalwort             String?  // "Achtung" | "Gefahr" | null
  createdAt              DateTime @default(now())
  updatedAt              DateTime @updatedAt

  inhaltsstoffe    ArtikelInhaltsstoff[]
  lieferanten      ArtikelLieferant[]
  kundePreise      KundeArtikelPreis[]
  preisHistorie    ArtikelPreisHistorie[]
  bedarfe          KundeBedarf[]
  lieferpositionen Lieferposition[]
  angebotPositionen AngebotPosition[]
  lagerbewegungen  Lagerbewegung[]
  wareineingangPos WareineingangPosition[]
  dokumente        ArtikelDokument[]
  mengenrabatte    Mengenrabatt[]
  inventurPositionen InventurPosition[]
  gutschriftPositionen GutschriftPosition[]
  bestellpositionen Bestellposition[]
  driveOrdnerId    String?  // Google Drive Folder ID
  kampagneArtikel      KampagneArtikel[]
  bestellungPositionen BestellungPosition[]
  kontraktPositionen   KontraktPosition[]
  angebotVorlagePositionen AngebotVorlagePosition[]
  chargenZertifikate   ChargenZertifikat[]
  vorbestellungPositionen VorbestellungPosition[]
  fruehbezugStaffeln   FruehbezugsStaffel[]
  anlieferungen        Anlieferung[]

  @@index([aktiv])
  @@index([kategorie])
  @@index([unterkategorie])
  @@index([name])
}

model ArtikelInhaltsstoff {
  id        Int    @id @default(autoincrement())
  artikelId Int
  name      String   // z.B. "Schwefel", "Rohprotein", "Bor"
  menge     Float?   // z.B. 90
  einheit   String?  // z.B. "%", "mg/kg", "g/l"

  artikel Artikel @relation(fields: [artikelId], references: [id], onDelete: Cascade)

  @@index([artikelId])
  @@index([name])
}

model ArtikelDokument {
  id          Int      @id @default(autoincrement())
  artikelId   Int
  name        String
  dateiname   String   // original filename
  pfad        String   // stored path under /uploads/artikel/
  typ         String?  // MIME type
  groesse     Int?     // bytes
  notiz       String?
  createdAt   DateTime @default(now())

  artikel Artikel @relation(fields: [artikelId], references: [id], onDelete: Cascade)
}

model ArtikelLieferant {
  id                  Int      @id @default(autoincrement())
  artikelId           Int
  lieferantId         Int
  lieferantenArtNr    String?
  einkaufspreis       Float    @default(0)
  mindestbestellmenge Float    @default(0)
  lieferzeitTage      Int      @default(3)
  bevorzugt           Boolean  @default(false)
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  artikel   Artikel   @relation(fields: [artikelId], references: [id], onDelete: Cascade)
  lieferant Lieferant @relation(fields: [lieferantId], references: [id], onDelete: Cascade)

  @@unique([artikelId, lieferantId])
}

// Preishistorie: jede Änderung am Standardpreis wird versioniert
model ArtikelPreisHistorie {
  id          Int      @id @default(autoincrement())
  artikelId   Int
  alterPreis  Float
  neuerPreis  Float
  geaendertAm DateTime @default(now())
  notiz       String?

  artikel Artikel @relation(fields: [artikelId], references: [id], onDelete: Cascade)
}

// ─── PREISE & KONDITIONEN ─────────────────────────────────────────────────────

model KundeArtikelPreis {
  id        Int      @id @default(autoincrement())
  kundeId   Int
  artikelId Int
  preis     Float
  rabatt    Float    @default(0) // Prozent
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  kunde   Kunde   @relation(fields: [kundeId], references: [id], onDelete: Cascade)
  artikel Artikel @relation(fields: [artikelId], references: [id], onDelete: Cascade)

  @@unique([kundeId, artikelId])
}

// ─── BEDARF (wiederkehrende Lieferungen) ──────────────────────────────────────

model KundeBedarf {
  id            Int      @id @default(autoincrement())
  kundeId       Int
  artikelId     Int
  menge         Float
  intervallTage Int      @default(30)
  notiz         String?
  aktiv         Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  kunde   Kunde   @relation(fields: [kundeId], references: [id], onDelete: Cascade)
  artikel Artikel @relation(fields: [artikelId], references: [id], onDelete: Cascade)

  @@unique([kundeId, artikelId])
}

// ─── LIEFERUNG ────────────────────────────────────────────────────────────────

model Lieferung {
  id               Int      @id @default(autoincrement())
  kundeId          Int
  datum            DateTime @default(now())
  lieferDatum      DateTime? // tatsächliches Lieferdatum (falls abweichend von datum) – erscheint auf der Rechnung
  status           String   @default("geplant") // geplant | geliefert | storniert
  stornoBegründung String?
  notiz            String?
  rechnungNr       String?  // gesetzt wenn Rechnung erstellt wurde
  rechnungDatum    DateTime?
  bezahltAm        DateTime?
  zahlungsziel     Int?      @default(30)  // Tage
  wiederkehrend    Boolean  @default(false) // wurde automatisch angelegt
  unterschriftPng  String?  // base64 PNG Kundenunterschrift bei Lieferung
  fahrerId             Int?     // zugewiesener Fahrer (Benutzer)
  istStreckengeschaeft Boolean  @default(false)  // Lieferant liefert direkt an Kunde
  streckenLieferantId  Int?     // Lieferant der direkt liefert
  skontoProzent        Float?   // z.B. 2.0 = 2% Skonto
  skontoTage           Int?     // z.B. 10 = Skonto wenn Zahlung binnen 10 Tagen
  skontoGenutzt        Boolean  @default(false)
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  kunde             Kunde            @relation(fields: [kundeId], references: [id])
  positionen        Lieferposition[]
  lagerbewegungen   Lagerbewegung[]
  sammelrechnung    Sammelrechnung?  @relation(fields: [sammelrechnungId], references: [id])
  sammelrechnungId  Int?
  gutschriften      Gutschrift[]
  bestellpositionen Bestellposition[]
  reklamationen     Reklamation[]
  streckenLieferant Lieferant?       @relation("StreckenLieferant", fields: [streckenLieferantId], references: [id])
  teilzahlungen     Teilzahlung[]

  @@index([kundeId])
  @@index([status])
  @@index([datum])
  @@index([status, datum])
  @@index([rechnungNr])
  @@index([bezahltAm])
}

model Lieferposition {
  id            Int     @id @default(autoincrement())
  lieferungId   Int
  artikelId     Int
  menge         Float
  verkaufspreis Float
  einkaufspreis Float   @default(0)
  chargeNr      String? // Chargen-/Losnummer (gesetzlich für Saatgut)
  rabattProzent Float   @default(0) // Mengenrabatt der angewendet wurde
  notiz         String? // Auftragsnummer / interne Notiz zur Position

  lieferung Lieferung @relation(fields: [lieferungId], references: [id], onDelete: Cascade)
  artikel   Artikel   @relation(fields: [artikelId], references: [id])

  @@index([lieferungId])
  @@index([artikelId])
}

// ─── WARENEINGANG ─────────────────────────────────────────────────────────────

model Wareneingang {
  id               Int      @id @default(autoincrement())
  lieferantId      Int
  datum            DateTime @default(now())
  notiz            String?
  istCrossDocking  Boolean  @default(false)
  lieferungId      Int?     // direkt verknüpfte Lieferung bei Cross-Docking
  createdAt        DateTime @default(now())

  lieferant       Lieferant              @relation(fields: [lieferantId], references: [id])
  positionen      WareineingangPosition[]
  lagerbewegungen Lagerbewegung[]
}

model WareineingangPosition {
  id                Int       @id @default(autoincrement())
  wareneingangId    Int
  artikelId         Int
  menge             Float
  einkaufspreis     Float
  chargeNr          String?   // Chargen-/Losnummer (gesetzlich für Saatgut)
  mhd               DateTime? // Mindesthaltbarkeitsdatum
  bestellpositionId Int?      // verknüpfte Bestellposition (erfüllt diese Bestellung)

  wareneingang   Wareneingang  @relation(fields: [wareneingangId], references: [id], onDelete: Cascade)
  artikel        Artikel       @relation(fields: [artikelId], references: [id])
  bestellposition Bestellposition? @relation(fields: [bestellpositionId], references: [id])

  @@index([wareneingangId])
  @@index([artikelId])
  @@index([bestellpositionId])
}

// ─── LAGERBEWEGUNG ────────────────────────────────────────────────────────────

model Lagerbewegung {
  id             Int      @id @default(autoincrement())
  artikelId      Int
  typ            String   // eingang | ausgang | korrektur | UMBUCHUNG
  menge          Float    // positiv = Zugang, negativ = Abgang
  bestandNach    Float
  datum          DateTime @default(now())
  notiz          String?
  lieferungId    Int?
  wareneingangId Int?
  chargeNr       String?  // Chargennummer (aus Wareneingang oder Lieferung)
  lagerortVon    String?  // source location (for Umbuchung)
  lagerortNach   String?  // target location (for Umbuchung)

  artikel      Artikel       @relation(fields: [artikelId], references: [id])
  lieferung    Lieferung?    @relation(fields: [lieferungId], references: [id])
  wareneingang Wareneingang? @relation(fields: [wareneingangId], references: [id])

  @@index([artikelId])
  @@index([datum])
  @@index([artikelId, datum])
  @@index([typ])
}

// ─── MENGENRABATTE ────────────────────────────────────────────────────────────

model Mengenrabatt {
  id            Int      @id @default(autoincrement())
  kundeId       Int?     // null = gilt für alle Kunden
  artikelId     Int?     // null = gilt für alle Artikel der Kategorie
  kategorie     String?  // alternativ zu artikelId: gilt für ganze Kategorie
  vonMenge      Float    // ab dieser Menge gilt der Rabatt
  rabattProzent Float    // Rabatt in %
  aktiv         Boolean  @default(true)
  createdAt     DateTime @default(now())

  kunde   Kunde?   @relation(fields: [kundeId], references: [id], onDelete: Cascade)
  artikel Artikel? @relation(fields: [artikelId], references: [id], onDelete: Cascade)
}

// ─── SAMMELRECHNUNG ───────────────────────────────────────────────────────────

model Sammelrechnung {
  id           Int      @id @default(autoincrement())
  kundeId      Int
  rechnungNr   String?
  rechnungDatum DateTime?
  bezahltAm   DateTime?
  zahlungsziel Int      @default(30)
  notiz        String?
  createdAt    DateTime @default(now())

  kunde       Kunde       @relation(fields: [kundeId], references: [id])
  lieferungen Lieferung[]
  teilzahlungen Teilzahlung[]
  skontoProzent Float?
  skontoTage    Int?
  skontoGenutzt Boolean  @default(false)
}

// ─── BESTELLLISTE (Lieferanten-Bestellungen) ─────────────────────────────────

model Bestellposition {
  id            Int       @id @default(autoincrement())
  lieferantId   Int
  artikelId     Int
  kundeId       Int?      // Rückverfolgbarkeit: welcher Kunde
  lieferungId   Int?      // Rückverfolgbarkeit: welche Lieferung
  angebotId     Int?      // Rückverfolgbarkeit: welches Angebot
  menge            Float
  mengeGeliefert   Float     @default(0) // Summe bereits gelieferter Mengen (Teillieferungen)
  einheit          String    @default("kg")
  einkaufspreis    Float     @default(0)
  status           String    @default("offen") // offen | bestellt | teilgeliefert | geliefert | storniert
  bestelltAm       DateTime?
  geliefertAm      DateTime?
  notiz            String?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  lieferant             Lieferant              @relation(fields: [lieferantId], references: [id])
  artikel               Artikel                @relation(fields: [artikelId], references: [id])
  kunde                 Kunde?                 @relation(fields: [kundeId], references: [id])
  lieferung             Lieferung?             @relation(fields: [lieferungId], references: [id])
  wareineingangPos      WareineingangPosition[]

  @@index([lieferantId])
  @@index([artikelId])
  @@index([status])
  @@index([lieferungId])
}

// ─── INVENTUR ────────────────────────────────────────────────────────────────

model Inventur {
  id          Int                @id @default(autoincrement())
  datum       DateTime           @default(now())
  status      String             @default("OFFEN") // OFFEN | ABGESCHLOSSEN
  bezeichnung String?
  positionen  InventurPosition[]

  @@index([status])
}

model InventurPosition {
  id          Int      @id @default(autoincrement())
  inventurId  Int
  inventur    Inventur @relation(fields: [inventurId], references: [id], onDelete: Cascade)
  artikelId   Int
  artikel     Artikel  @relation(fields: [artikelId], references: [id])
  sollBestand Float    // snapshot of bestand at time of inventur
  istBestand  Float?   // counted value
  differenz   Float?   // computed: istBestand - sollBestand
  bemerkung   String?
  chargeNr    String?  // Chargennummer bei der Zählung (für chargenpflichtige Artikel)

  @@index([inventurId])
  @@index([artikelId])
}

// ─── SYSTEM: Rechnungsnummer-Zähler ──────────────────────────────────────────

model Einstellung {
  key   String @id
  value String
}

// ─── OPEN DATA: Marktpreise (Eurostat) ───────────────────────────────────────

model MarktpreisCache {
  id          Int      @id @default(autoincrement())
  dataset     String   // "apri_pi15_inq" (quartalsweise) oder "apri_pi15_ina" (jährlich)
  produktCode String   // z.B. "206000" (Futtermittel)
  produktName String   // z.B. "Futtermittel"
  zeitraum    String   // z.B. "2024-Q3" oder "2024"
  indexWert   Float    // Indexwert (2015 = 100)
  einheit     String   @default("I15")
  land        String   @default("DE")
  abgerufenAm DateTime @default(now())
  createdAt   DateTime @default(now())

  @@unique([dataset, produktCode, zeitraum, land])
}

// ─── OPEN DATA: Agrarflächen (Overpass / OSM) ────────────────────────────────

model AgrarflaechenCache {
  id           Int      @id @default(autoincrement())
  lat          Float
  lng          Float
  radius       Int      // Meter
  flaecheHa    Float    // Gesamtfläche in Hektar
  polygonCount Int      // Anzahl Polygone
  geojson      String   // GeoJSON FeatureCollection
  abgerufenAm  DateTime @default(now())
  createdAt    DateTime @default(now())

  @@unique([lat, lng, radius])
}

// ─── AGRARANTRÄGE (AFIG / agrarzahlungen.de) ──────────────────────────────────

model AntragEmpfaenger {
  id                        Int      @id @default(autoincrement())
  haushaltsjahr             Int
  name                      String   // Name des Begünstigten
  plz                       String?
  gemeinde                  String?
  land                      String?
  steuerNr                  String?  // Steuerliches Identifikationsmerkmal
  egflGesamt                Float    @default(0)  // EGFL-Gesamtbetrag für diesen Begünstigten (Spalte 12)
  elerGesamt                Float    @default(0)  // ELER-Gesamtbetrag EU-Mittel (Spalte 14)
  nationalKofiGesamt        Float    @default(0)  // National kofinanzierter Gesamtbetrag (Spalte 16)
  elerUndKofiGesamt         Float    @default(0)  // ELER + national Kofi (Spalte 17)
  gesamtBetrag              Float    @default(0)  // EU-Betrag + Kofi gesamt (Spalte 18)
  massnahmen                String?  // JSON: [{code, ziel, egfl, eler, nationalKofi, anfang, ende}]
  mutterunternehmen         String?
  importiertAm              DateTime @default(now())

  kundeId           Int?
  kunde             Kunde?   @relation(fields: [kundeId], references: [id], onDelete: SetNull)

  @@index([name])
  @@index([plz])
  @@index([gemeinde])
  @@index([haushaltsjahr])
  @@index([kundeId])
}

// ─── AUFGABEN / TODO ──────────────────────────────────────────────────────────

model Aufgabe {
  id           Int       @id @default(autoincrement())
  betreff      String
  beschreibung String?
  faelligAm    DateTime?
  erledigt     Boolean   @default(false)
  erledigtAm   DateTime?
  prioritaet   String    @default("normal")  // niedrig | normal | hoch | kritisch
  tags         String    @default("[]")       // JSON array of strings
  typ          String    @default("aufgabe")  // aufgabe | anruf | besuch | email
  kundeId      Int?
  erstellt     DateTime  @default(now())
  aktualisiert DateTime  @updatedAt

  kunde        Kunde?    @relation(fields: [kundeId], references: [id], onDelete: SetNull)

  @@index([kundeId])
  @@index([erledigt])
  @@index([faelligAm])
  @@index([erledigt, faelligAm])
  @@index([kundeId, erledigt])
}

// ─── ANGEBOTSWESEN ────────────────────────────────────────────────────────────

model Angebot {
  id          Int      @id @default(autoincrement())
  nummer      String   @unique          // z.B. AN-2026-0001
  datum       DateTime @default(now())
  gueltigBis  DateTime?
  status      String   @default("OFFEN") // OFFEN | ANGENOMMEN | ABGELEHNT | ABGELAUFEN
  kundeId     Int
  notiz       String?
  erstellt    DateTime @default(now())
  aktualisiert DateTime @updatedAt

  kunde       Kunde            @relation(fields: [kundeId], references: [id], onDelete: Cascade)
  positionen  AngebotPosition[]

  @@index([kundeId])
  @@index([status])
  @@index([datum])
}

model AngebotPosition {
  id         Int    @id @default(autoincrement())
  angebotId  Int
  artikelId  Int
  menge      Float
  preis      Float  // Angebotspreis (netto)
  rabatt     Float  @default(0)
  einheit    String @default("kg")
  notiz      String?

  angebot    Angebot @relation(fields: [angebotId], references: [id], onDelete: Cascade)
  artikel    Artikel @relation(fields: [artikelId], references: [id])

  @@index([angebotId])
  @@index([artikelId])
}

// ─── GUTSCHRIFTEN / RETOUREN ──────────────────────────────────────────────────

model Gutschrift {
  id          Int      @id @default(autoincrement())
  nummer      String   @unique  // GS-YYYY-NNNN
  kundeId     Int
  lieferungId Int?     // optional reference to original delivery
  datum       DateTime @default(now())
  grund       String   // Reklamation | Retoure | Preiskorrektur | Sonstiges
  notiz       String?
  status      String   @default("OFFEN")  // OFFEN | VERBUCHT | STORNIERT
  createdAt   DateTime @default(now())

  kunde       Kunde              @relation(fields: [kundeId], references: [id])
  lieferung   Lieferung?         @relation(fields: [lieferungId], references: [id])
  positionen  GutschriftPosition[]
  anlieferung Anlieferung?

  @@index([kundeId])
  @@index([datum])
}

model GutschriftPosition {
  id           Int     @id @default(autoincrement())
  gutschriftId Int
  artikelId    Int
  menge        Float
  preis        Float   // unit price for credit
  ruecknahme   Boolean @default(false)  // true = return to stock

  gutschrift   Gutschrift @relation(fields: [gutschriftId], references: [id], onDelete: Cascade)
  artikel      Artikel    @relation(fields: [artikelId], references: [id])
}

// ─── AUDIT-LOG ────────────────────────────────────────────────────────────────

model AuditLog {
  id           Int      @id @default(autoincrement())
  zeitpunkt    DateTime @default(now())
  entitaet     String   // "Kunde" | "Artikel" | "Lieferung" | "Lager" | etc.
  entitaetId   Int      // ID des betroffenen Datensatzes
  aktion       String   // "erstellt" | "geaendert" | "geloescht"
  feld         String?  // welches Feld geändert wurde (null bei erstellt/geloescht)
  alterWert    String?  // alter Wert (als String)
  neuerWert    String?  // neuer Wert (als String)
  beschreibung String?  // lesbare Beschreibung

  @@index([entitaet, entitaetId])
  @@index([zeitpunkt])
}

// ─── SCHLAGKARTEI ─────────────────────────────────────────────────────────────

model KundeSchlag {
  id         Int      @id @default(autoincrement())
  kundeId    Int
  name       String                          // Schlagname / Feldname
  flaeche    Float                           // ha
  fruchtart  String?                         // Weizen, Raps, Gerste …
  sorte      String?                         // Sortenname
  vorfrucht  String?
  aussaatJahr Int?
  aussaatMenge Float?                        // kg/ha
  notiz      String?
  erstellt   DateTime @default(now())

  kunde            Kunde            @relation(fields: [kundeId], references: [id], onDelete: Cascade)
  psmAusbringungen PsmAusbringung[]
  bodenproben      Bodenprobe[]
  albrechtAnalysen BodenanalyseAlbrecht[]
  duengebedarfe    Duengebedarf[]
  sortenversuche   Sortenversuch[]
  anbauplaene      Anbauplan[]

  @@index([kundeId])
}

// ─── AUSGABENBUCH (Betriebsausgaben / Eingangsrechnungen) ─────────────────────

model Ausgabe {
  id           Int       @id @default(autoincrement())
  datum        DateTime  @default(now())
  belegNr      String?   // Eingangsrechnungsnummer des Lieferanten
  beschreibung String
  betragNetto  Float
  mwstSatz     Float     @default(19) // 0 | 7 | 19
  kategorie    String    @default("Sonstige")
  // Kategorien: Wareneinkauf | Betriebsbedarf | Fahrtkosten | Bürobedarf |
  //             Telefon/Internet | Versicherung | Miete | Sonstige
  lieferantId  Int?
  lieferant    Lieferant? @relation(fields: [lieferantId], references: [id], onDelete: SetNull)
  bezahltAm      DateTime?
  notiz          String?
  belegPfad      String?   // Relativer Pfad zur hochgeladenen Belegdatei (z.B. /uploads/belege/2026/20260403_42_RE-2026-1234.jpg)
  belegDateiname String?   // Originaler Dateiname des Belegs
  ausleger       String?   // Name der Person, die privat ausgelegt hat (null = Firmenzahlung)
  erfasstVon     String?   // Benutzername der erfassenden Person
  bezahltVon     String?   // Benutzername der Person, die als bezahlt markiert hat
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  @@index([datum])
  @@index([lieferantId])
  @@index([kategorie])
  @@index([ausleger])
  @@index([erfasstVon])
}

// ─── BANKABGLEICH (Kontoauszug-Import & Zahlungszuordnung) ───────────────────

model Kontoumsatz {
  id               Int       @id @default(autoincrement())
  kontoBezeichnung String?   // z.B. "Geschäftskonto Sparkasse"
  buchungsdatum    DateTime
  wertstellung     DateTime?
  betrag           Float     // positiv = Eingang, negativ = Ausgang
  waehrung         String    @default("EUR")
  verwendungszweck String
  gegenkonto       String?   // IBAN der Gegenpartei
  gegenkontoName   String?   // Name der Gegenpartei
  saldo            Float?
  zugeordnet       Boolean   @default(false)
  lieferungId      Int?
  sammelrechnungId Int?
  ausgabeId        Int?      // Zuordnung zu Betriebsausgabe
  importDatum      DateTime  @default(now())
  importDatei      String?   // Name der Importdatei (für Rückverfolgung)

  @@index([buchungsdatum])
  @@index([zugeordnet])
  @@index([betrag])
}

// ─── KI-NUTZUNG (AI Usage Statistics) ────────────────────────────────────────

model KiNutzung {
  id          Int      @id @default(autoincrement())
  zeitpunkt   DateTime @default(now())
  provider    String                           // "openai" | "anthropic"
  modell      String                           // "gpt-4o" | "claude-sonnet-4-20250514" etc.
  feature     String                           // "wareneingang" | "lieferung" | "crm"
  tokensIn    Int
  tokensOut   Int
  kostenCent  Int      @default(0)
  erfolgreich Boolean  @default(true)
  fehler      String?

  @@index([zeitpunkt, feature])
}

// ─── BENUTZER ─────────────────────────────────────────────────────────────────

model Benutzer {
  id           Int       @id @default(autoincrement())
  benutzername String    @unique
  passwortHash String
  name         String
  email        String?
  rolle        String    @default("benutzer") // "admin" | "benutzer"
  aktiv        Boolean   @default(true)
  letzterLogin DateTime?
  erstelltAm   DateTime  @default(now())
  geaendertAm  DateTime  @updatedAt

  @@index([aktiv])
}

// ─── PSM-AUSBRINGUNG (Pflanzenschutz) ─────────────────────────────────────────

model PsmAusbringung {
  id              Int       @id @default(autoincrement())
  kundeId         Int
  schlagId        Int?
  datum           DateTime
  mittel          String    // PSM-Mittelname
  wirkstoff       String?
  menge           Float
  einheit         String    @default("l/ha")
  kultur          String?
  flaeche         Float?    // ha
  anwendungsgrund String?
  wartezeit       Int?      // Tage
  notiz           String?
  createdAt       DateTime  @default(now())

  kunde  Kunde        @relation(fields: [kundeId], references: [id], onDelete: Cascade)
  schlag KundeSchlag? @relation(fields: [schlagId], references: [id], onDelete: SetNull)

  @@index([kundeId])
  @@index([datum])
}

// ─── FORMELLE LIEFERANTENBESTELLUNG ──────────────────────────────────────────

model Bestellung {
  id          Int       @id @default(autoincrement())
  nummer      String    @unique  // BES-YYYY-NNNN
  lieferantId Int
  datum       DateTime  @default(now())
  lieferdatum DateTime?
  status      String    @default("OFFEN")  // OFFEN|BESTAETIGT|TEILGELIEFERT|ABGESCHLOSSEN|STORNIERT
  notiz       String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  lieferant  Lieferant           @relation(fields: [lieferantId], references: [id])
  positionen BestellungPosition[]

  @@index([lieferantId])
  @@index([status])
  @@index([datum])
}

model BestellungPosition {
  id              Int     @id @default(autoincrement())
  bestellungId    Int
  artikelId       Int
  menge           Float
  mengeGeliefert  Float   @default(0)
  preis           Float?
  einheit         String  @default("kg")

  bestellung Bestellung @relation(fields: [bestellungId], references: [id], onDelete: Cascade)
  artikel    Artikel    @relation(fields: [artikelId], references: [id])

  @@index([bestellungId])
  @@index([artikelId])
}

// ─── KONTRAKTE (Rahmenverträge) ───────────────────────────────────────────────

model Kontrakt {
  id              Int       @id @default(autoincrement())
  nummer          String    @unique  // KON-YYYY-NNNN
  kundeId         Int
  datum           DateTime  @default(now())
  gueltigVon      DateTime
  gueltigBis      DateTime
  status          String    @default("AKTIV")  // AKTIV|ABGESCHLOSSEN|STORNIERT
  notiz           String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  kunde      Kunde              @relation(fields: [kundeId], references: [id], onDelete: Cascade)
  positionen KontraktPosition[]

  @@index([kundeId])
  @@index([status])
  @@index([gueltigBis])
}

model KontraktPosition {
  id             Int     @id @default(autoincrement())
  kontraktId     Int
  artikelId      Int
  menge          Float
  mengeAbgerufen Float   @default(0)
  preis          Float?
  einheit        String  @default("kg")

  kontrakt Kontrakt @relation(fields: [kontraktId], references: [id], onDelete: Cascade)
  artikel  Artikel  @relation(fields: [artikelId], references: [id])

  @@index([kontraktId])
  @@index([artikelId])
}

// ─── KAMPAGNEN / AKTIONSPREISE ────────────────────────────────────────────────

model Kampagne {
  id            Int       @id @default(autoincrement())
  name          String
  beschreibung  String?
  von           DateTime
  bis           DateTime
  rabattProzent Float?
  aktiv         Boolean   @default(true)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  artikel KampagneArtikel[]

  @@index([aktiv])
  @@index([bis])
}

model KampagneArtikel {
  id          Int     @id @default(autoincrement())
  kampagneId  Int
  artikelId   Int
  sonderpreis Float?

  kampagne Kampagne @relation(fields: [kampagneId], references: [id], onDelete: Cascade)
  artikel  Artikel  @relation(fields: [artikelId], references: [id], onDelete: Cascade)

  @@unique([kampagneId, artikelId])
  @@index([kampagneId])
  @@index([artikelId])
}

// ─── REKLAMATIONSMANAGEMENT ───────────────────────────────────────────────────

model Reklamation {
  id           Int       @id @default(autoincrement())
  nummer       String    @unique  // RK-YYYY-NNNN
  kundeId      Int
  lieferungId  Int?
  datum        DateTime  @default(now())
  betreff      String
  beschreibung String
  kategorie    String    @default("Qualitaet")  // Qualitaet|Menge|Lieferung|Preis|Sonstiges
  prioritaet   String    @default("normal")      // niedrig|normal|hoch|kritisch
  status       String    @default("OFFEN")        // OFFEN|IN_BEARBEITUNG|GELOEST|GESCHLOSSEN
  zugewiesen   String?   // Mitarbeiter-Name
  loesung      String?
  geloestAm    DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  kunde     Kunde      @relation(fields: [kundeId], references: [id], onDelete: Cascade)
  lieferung Lieferung? @relation(fields: [lieferungId], references: [id], onDelete: SetNull)

  @@index([kundeId])
  @@index([status])
  @@index([datum])
  @@index([prioritaet])
}

// ─── BENACHRICHTIGUNGEN ───────────────────────────────────────────────────────

model Benachrichtigung {
  id         Int      @id @default(autoincrement())
  typ        String   // "lagerbestand" | "sachkunde" | "kreditlimit" | "rechnung_faellig" | "reklamation"
  titel      String
  text       String
  prioritaet String   @default("info")  // "info" | "warnung" | "kritisch"
  gelesen    Boolean  @default(false)
  kundeId    Int?
  artikelId  Int?
  link       String?  // Ziel-URL für Klick
  createdAt  DateTime @default(now())

  @@index([gelesen])
  @@index([createdAt])
  @@index([typ])
}

// ─── EINGANGSRECHNUNGEN (Lieferanten) ─────────────────────────────────────────

model EingangsRechnung {
  id          Int       @id @default(autoincrement())
  nummer      String?   // Rechnungsnummer des Lieferanten
  lieferantId Int
  datum       DateTime
  faelligAm   DateTime?
  betrag      Float
  mwst        Float     @default(19)
  status      String    @default("OFFEN")  // OFFEN|BEZAHLT|STORNIERT
  belegpfad   String?
  notiz       String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  lieferant Lieferant @relation(fields: [lieferantId], references: [id])

  @@index([lieferantId])
  @@index([status])
  @@index([faelligAm])
}

// ─── TEILZAHLUNGEN ────────────────────────────────────────────────────────────

model Teilzahlung {
  id               Int      @id @default(autoincrement())
  lieferungId      Int?
  sammelrechnungId Int?
  betrag           Float
  datum            DateTime @default(now())
  notiz            String?
  createdAt        DateTime @default(now())

  lieferung      Lieferung?      @relation(fields: [lieferungId], references: [id], onDelete: Cascade)
  sammelrechnung Sammelrechnung? @relation(fields: [sammelrechnungId], references: [id], onDelete: Cascade)

  @@index([lieferungId])
  @@index([sammelrechnungId])
}

// ─── ANGEBOTS-VORLAGEN ────────────────────────────────────────────────────────

model AngebotVorlage {
  id           Int      @id @default(autoincrement())
  name         String
  beschreibung String?
  notiz        String?
  aktiv        Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  positionen AngebotVorlagePosition[]
}

model AngebotVorlagePosition {
  id        Int    @id @default(autoincrement())
  vorlageId Int
  artikelId Int
  menge     Float
  preis     Float  @default(0)  // 0 = aktuellen Standardpreis verwenden
  rabatt    Float  @default(0)
  einheit   String @default("kg")
  notiz     String?

  vorlage AngebotVorlage @relation(fields: [vorlageId], references: [id], onDelete: Cascade)
  artikel Artikel        @relation(fields: [artikelId], references: [id])

  @@index([vorlageId])
}

// ─── CHARGEN-ZERTIFIKATE ──────────────────────────────────────────────────────

model ChargenZertifikat {
  id        Int      @id @default(autoincrement())
  chargeNr  String
  artikelId Int
  dateiname String
  pfad      String   // /uploads/zertifikate/
  typ       String?  // MIME type
  groesse   Int?
  notiz     String?
  createdAt DateTime @default(now())

  artikel Artikel @relation(fields: [artikelId], references: [id], onDelete: Cascade)

  @@index([chargeNr])
  @@index([artikelId])
}

// ─── BUDGETPLANUNG ────────────────────────────────────────────────────────────

model Umsatzziel {
  id         Int      @id @default(autoincrement())
  jahr       Int
  monat      Int?     // null = Jahresziel
  kategorie  String?  // null = gesamt; "Futter" | "Duenger" | "Saatgut" etc.
  zielBetrag Float
  notiz      String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@unique([jahr, monat, kategorie])
  @@index([jahr])
}

// ─── BODENPROBEN ──────────────────────────────────────────────────────────────

model Bodenprobe {
  id           Int       @id @default(autoincrement())
  schlagId     Int
  datum        DateTime                // Probenahmedatum
  probenNr     String?                 // Labor-Probennummer
  labor        String?                 // LUFA-NW | Eurofins | LKS | ...
  tiefe        String?                 // "0-30 cm" | "30-60 cm"
  pH           Float?
  phosphor     Float?                  // P2O5 mg/100g Boden (CAL)
  kalium       Float?                  // K2O mg/100g (CAL)
  magnesium    Float?                  // Mg mg/100g (CaCl2)
  bor          Float?                  // mg/kg
  humus        Float?                  // %
  nMin         Float?                  // kg N/ha (0-90cm)
  cn           Float?                  // C/N-Verhältnis
  bodenart     String?                 // S | lS | sL | L | T
  bodenartGruppe String?               // z.B. "(h)" humos, "(s)" sandig — IfB/LUFA-NW-Zusatz
  nutzungsart  String?                 // A=Acker | W=Grünland | G=Garten | F=Forst | O=Obstbau | X=Sonstige
  pHSoll       String?                 // anzustrebender pH-Bereich z.B. "6,3-7,0"
  auftragsNr   String?                 // Labor-Auftrags-Nr.
  probenehmer  String?                 // "Auftraggeber" | Labormitarbeiter
  kundeNrLabor String?                 // Kunden-Nr. beim Labor
  // Erweiterte Nährstoff-Werte
  schwefel     Float?                  // SO₃ mg/100g (CAT) — wichtig für Raps, Mais, Getreide
  zink         Float?                  // mg/kg (CAT)
  kupfer       Float?                  // mg/kg (CAT)
  mangan       Float?                  // mg/kg (CAT)
  natrium      Float?                  // Na mg/kg (CAT)
  kak          Float?                  // Kationenaustauschkapazität cmol+/kg
  kalkbedarf   Float?                  // Kalkbedarf in t CaO/ha (aus pH + Bodenart, legacy)
  kalkbedarfDt Float?                  // Kalkbedarf in dt CaO/ha — IfB/LUFA-Format
  corg         Float?                  // Kohlenstoff (Corg) %
  nGesamt      Float?                  // Gesamt-Stickstoff (N) %
  // Versorgungsklassen pro Nährstoff (VDLUFA/LWK Niedersachsen A–F)
  klasse       String?                 // DEPRECATED — Sammel-Versorgungsklasse; Werte werden in klasseP/K/Mg gespiegelt
  klasseP      String?
  klasseK      String?
  klasseMg     String?
  klasseBor    String?
  klasseSchwefel String?
  klasseZink   String?
  klasseKupfer String?
  klasseMangan String?
  klasseNatrium String?
  // Düngungsempfehlung als JSON-Blob (Tabelle aus PDF-Anlage)
  empfehlungenJson String?             // {kalkDtHa, p2o5: {nutzung: kg}, k2o, mgO, cu, mn, b, zn, na}
  notiz        String?
  belegPfad    String?                 // /uploads/bodenproben/<id>.pdf
  belegName    String?
  createdAt    DateTime  @default(now())

  schlag       KundeSchlag    @relation(fields: [schlagId], references: [id], onDelete: Cascade)
  duengebedarfe Duengebedarf[]

  @@index([schlagId])
  @@index([datum])
}

// ─── DÜNGEBEDARFSERMITTLUNG (DüV) ────────────────────────────────────────────

model Duengebedarf {
  id            Int       @id @default(autoincrement())
  schlagId      Int
  jahr          Int                       // Düngejahr
  fruchtart     String                    // Snapshot zum Berechnungszeitpunkt
  ertragsZiel   Float?                    // dt/ha
  vorfrucht     String?
  bodenprobeId  Int?
  nBedarf       Float                     // kg N/ha (Ergebnis)
  pBedarf       Float                     // kg P2O5/ha
  kBedarf       Float                     // kg K2O/ha
  mgBedarf      Float?                    // kg MgO/ha
  parameter     String?                   // JSON: Berechnungs-Snapshot (Eingaben)
  notiz         String?
  berechnetAm   DateTime  @default(now())

  schlag     KundeSchlag @relation(fields: [schlagId], references: [id], onDelete: Cascade)
  bodenprobe Bodenprobe? @relation(fields: [bodenprobeId], references: [id], onDelete: SetNull)

  @@index([schlagId])
  @@index([jahr])
}

// ─── SACHKUNDENACHWEISE ───────────────────────────────────────────────────────

model Sachkundenachweis {
  id              Int       @id @default(autoincrement())
  kundeId         Int
  typ             String                  // "PSM-Sachkunde" | "Spritzgeraetekontrolle" | "Duengerschulung" | "Sprengstoff-Sachkunde" | "Sonstige"
  nummer          String?
  ausstellung     DateTime?
  gueltigBis      DateTime?
  ausgestelltVon  String?                 // Behörde / Kammer
  notiz           String?
  belegPfad       String?                 // /uploads/sachkunde/<id>.pdf
  belegName       String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  kunde Kunde @relation(fields: [kundeId], references: [id], onDelete: Cascade)

  @@index([kundeId])
  @@index([gueltigBis])
  @@index([typ])
}

// ─── SORTENVERSUCHE / DEMOFLÄCHEN ─────────────────────────────────────────────

model Sortenversuch {
  id           Int       @id @default(autoincrement())
  name         String                    // "Wintergerste-Versuch 2025 Süd"
  jahr         Int
  kultur       String                    // Wintergerste | Mais | Raps | ...
  standort     String?
  kundeId      Int?
  schlagId     Int?
  flaeche      Float?                    // ha
  status       String    @default("LAUFEND") // LAUFEND | ABGESCHLOSSEN
  startDatum   DateTime?
  endeDatum    DateTime?
  notiz        String?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  kunde        Kunde?       @relation(fields: [kundeId], references: [id], onDelete: SetNull)
  schlag       KundeSchlag? @relation(fields: [schlagId], references: [id], onDelete: SetNull)
  positionen   SortenversuchPosition[]

  @@index([jahr])
  @@index([kultur])
  @@index([kundeId])
}

model SortenversuchPosition {
  id              Int     @id @default(autoincrement())
  versuchId       Int
  sorte           String
  saatstaerke     Float?                  // Körner/m² oder kg/ha
  ertragDtHa      Float?                  // dt/ha
  feuchteProzent  Float?
  proteinProzent  Float?
  hektolitergew   Float?                  // kg/hl (Getreide)
  bonitur         Int?                    // 1-9 Note (Krankheit/Lager)
  reife           String?                 // früh | mittel | spät
  notiz           String?

  versuch Sortenversuch @relation(fields: [versuchId], references: [id], onDelete: Cascade)

  @@index([versuchId])
  @@index([sorte])
}

// ─── VORBESTELLUNGEN (Saison-/Frühbezug) ──────────────────────────────────────

model Vorbestellung {
  id              Int       @id @default(autoincrement())
  nummer          String    @unique               // VB-YYYY-NNNN
  kundeId         Int
  saison          String                          // "Frühjahr 2026" | "Herbst 2026"
  bestelldatum    DateTime  @default(now())
  lieferdatum     DateTime?                       // gewünschtes Lieferdatum
  bestellfrist    DateTime?                       // Frist für Frühbezug
  status          String    @default("OFFEN")     // OFFEN | BESTAETIGT | UMGEWANDELT | STORNIERT
  rabattProzent   Float?                          // gewährter Frühbezugs-Rabatt
  notiz           String?
  lieferungId     Int?                            // bei Umwandlung zur Lieferung
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  kunde      Kunde                  @relation(fields: [kundeId], references: [id], onDelete: Cascade)
  positionen VorbestellungPosition[]

  @@index([kundeId])
  @@index([status])
  @@index([bestellfrist])
  @@index([saison])
}

model VorbestellungPosition {
  id              Int     @id @default(autoincrement())
  vorbestellungId Int
  artikelId       Int
  menge           Float
  preis           Float?                  // Frühbezugspreis (netto, optional)
  einheit         String  @default("kg")
  reserviert      Boolean @default(false) // automatische Lagerreservierung gesetzt?
  notiz           String?

  vorbestellung Vorbestellung @relation(fields: [vorbestellungId], references: [id], onDelete: Cascade)
  artikel       Artikel       @relation(fields: [artikelId], references: [id])

  @@index([vorbestellungId])
  @@index([artikelId])
}

model FruehbezugsStaffel {
  id              Int       @id @default(autoincrement())
  saison          String                          // "Frühjahr 2026"
  kategorie       String?                         // null = alle Kategorien
  artikelId       Int?                            // null = ganze Kategorie / alle
  bestellfrist    DateTime                        // bis wann muss bestellt sein
  rabattProzent   Float                           // 3.0 = -3%
  beschreibung    String?
  aktiv           Boolean   @default(true)
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  artikel Artikel? @relation(fields: [artikelId], references: [id], onDelete: Cascade)

  @@index([saison])
  @@index([bestellfrist])
  @@index([aktiv])
}

// ─── EINKAUFSZETTEL / BESCHAFFUNGSSTATUS ──────────────────────────────────────
// Markiert, ob eine Quell-Auftragsposition (Vorbestellung/Lieferung/Angebot)
// bereits beim Lieferanten bestellt wurde — verhindert Doppelbestellungen und
// liefert den grünen Haken inkl. Bestelldatum auf der Auftragsbestätigung.
model EinkaufStatus {
  id          Int      @id @default(autoincrement())
  quelle      String   // "vorbestellung" | "lieferung" | "angebot"
  positionId  Int      // ID der Quell-Position (VorbestellungPosition/Lieferposition/AngebotPosition)
  artikelId   Int
  lieferantId Int?     // bei welchem Lieferanten bestellt wurde
  menge       Float
  einheit     String   @default("kg")
  bestelltAm  DateTime @default(now())
  notiz       String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([quelle, positionId])
  @@index([artikelId])
  @@index([lieferantId])
  @@index([quelle])
}

// ─── TIERHALTUNG / RATIONSBERECHNUNG ──────────────────────────────────────────

/// Tier/Tiergruppe (Herde) je Kunde — Basis für die Rationsberechnung.
model KundeTier {
  id            Int      @id @default(autoincrement())
  kundeId       Int
  name          String                       // z.B. "Milchkuhherde Stall 1", "Wallach Falko"
  tierart       String                       // Rind | Schwein | Geflugel | Pferd | Schaf | Ziege
  nutzungsart   String                       // z.B. "Milchkuh laktierend", "Mastschwein Endmast", "Pferd Warmblut leichte Arbeit"
  rasse         String?
  anzahl        Int      @default(1)          // Tierzahl in der Gruppe
  gewicht       Float?                        // durchschnittl. Lebendgewicht kg
  leistung      Float?                        // Leistung: Milch kg/Tag | tgl. Zunahme g | Eier/Tag | …
  leistungEinheit String?                     // "kg Milch/Tag" | "g Zunahme/Tag" | …
  laktationstag Int?                          // optional bei Milchvieh
  notiz         String?
  erstellt      DateTime @default(now())
  aktualisiert  DateTime @updatedAt

  kunde               Kunde               @relation(fields: [kundeId], references: [id], onDelete: Cascade)
  rationsberechnungen Rationsberechnung[]

  @@index([kundeId])
  @@index([tierart])
}

// ─── ALBRECHT-BODENANALYSE ────────────────────────────────────────────────────

model BodenanalyseAlbrecht {
  id              Int       @id @default(autoincrement())
  schlagId        Int
  datum           DateTime
  probenId        String?   // Labor-Proben-ID (z.B. 26CB2353)
  kultur          String?   // Zielkultur (z.B. KLG - TRI)
  tiefe           String?
  bodenart        String?

  // Basisdaten
  phH2O           Float?
  phKCl           Float?
  kak             Float?    // mmol/100g
  humus           Float?    // %
  nGesamt         Float?    // %
  cn              Float?
  nNachlieferung  Float?    // kg/ha
  caCo3           Float?    // %
  leitfaehigkeit  Float?    // mS/cm

  // Kationen-Sättigung %
  caSaettigung    Float?
  mgSaettigung    Float?
  kSaettigung     Float?
  naSaettigung    Float?
  hSaettigung     Float?
  variabelSaett   Float?

  // Kationen-Vorräte kg/ha
  caVorrat        Float?
  mgVorrat        Float?
  kVorrat         Float?
  naVorrat        Float?

  // Anionen + Phosphor
  schwefel        Float?    // ppm
  p2o5Verfuegbar  Float?    // kg/ha
  p2o5Vorrat      Float?    // kg/ha

  // Spurenelemente ppm
  bor             Float?
  eisen           Float?
  mangan          Float?
  kupfer          Float?
  zink            Float?
  chlorid         Float?
  silizium        Float?
  kobalt          Float?
  molybdaen       Float?
  selen           Float?

  // Empfehlungen aus Bericht (JSON: [{mittel, menge, einheit, prioritaet}])
  empfehlungenJson String?

  notiz           String?
  belegPfad       String?
  belegName       String?
  createdAt       DateTime @default(now())

  schlag          KundeSchlag @relation(fields: [schlagId], references: [id], onDelete: Cascade)

  @@index([schlagId])
  @@index([datum])
}

/// Gespeicherte Rationsberechnung. Positionen + Ergebnis + Rechenweg als JSON-Snapshot in `parameter`.
model Rationsberechnung {
  id           Int      @id @default(autoincrement())
  bezeichnung  String
  tierart      String                        // Rind | Schwein | Geflugel | Pferd | Schaf | Ziege
  nutzungsart  String
  modus        String   @default("simple")   // simple | detail
  kundeId      Int?                           // frei rechenbar → optional
  kundeTierId  Int?                           // an hinterlegtes Tier gebunden → optional
  gewicht      Float?
  leistung     Float?
  parameter    String                         // JSON: { eingaben, positionen[], bedarf, summe, bilanz, rechenweg, hinweise }
  notiz        String?
  erstellt     DateTime @default(now())
  aktualisiert DateTime @updatedAt

  kunde     Kunde?     @relation(fields: [kundeId], references: [id], onDelete: SetNull)
  kundeTier KundeTier? @relation(fields: [kundeTierId], references: [id], onDelete: SetNull)

  @@index([kundeId])
  @@index([kundeTierId])
  @@index([tierart])
  @@index([erstellt])
}

// ─── ERZEUGERABRECHNUNG (ANLIEFERUNG) ─────────────────────────────────────────

model Anlieferung {
  id              Int      @id @default(autoincrement())
  nummer          String   @unique  // ANL-YYYY-NNNN
  datum           DateTime @default(now())
  kundeId         Int
  artikelId       Int
  menge           Float
  einheit         String   @default("t")
  feuchte         Float?   // % Restfeuchte
  qualitaet       String?  // z.B. "A-Qualität", "Futtergetreide"
  preisProEinheit Float?
  gesamtBetrag    Float?
  notiz           String?
  gutschriftId    Int?     @unique  // verknüpfte Gutschrift wenn erstellt
  createdAt       DateTime @default(now())

  kunde     Kunde      @relation(fields: [kundeId], references: [id])
  artikel   Artikel    @relation(fields: [artikelId], references: [id])
  gutschrift Gutschrift? @relation(fields: [gutschriftId], references: [id])

  @@index([kundeId])
  @@index([datum])
}

// ─── KUNDEN-SELF-SERVICE-PORTAL ───────────────────────────────────────────────

model KundePortalZugang {
  id            Int      @id @default(autoincrement())
  kundeId       Int      @unique
  benutzername  String   @unique
  passwortHash  String
  aktiv         Boolean  @default(true)
  letzterLogin  DateTime?
  createdAt     DateTime @default(now())

  kunde         Kunde    @relation(fields: [kundeId], references: [id], onDelete: Cascade)
}

// ─── DIGITALE ANBAUPLANUNG (FRUCHTFOLGE) ──────────────────────────────────────

model Anbauplan {
  id           Int      @id @default(autoincrement())
  schlagId     Int
  kundeId      Int
  jahr         Int
  fruchtart    String
  sorte        String?
  aussaatDatum DateTime?
  ernteDatum   DateTime?
  ertragDt     Float?   // dt/ha
  status       String   @default("geplant") // geplant | ausgesaet | geerntet | abgebrochen
  notiz        String?
  erstellt     DateTime @default(now())

  schlag  KundeSchlag @relation(fields: [schlagId], references: [id], onDelete: Cascade)
  kunde   Kunde       @relation(fields: [kundeId], references: [id], onDelete: Cascade)

  @@index([schlagId])
  @@index([kundeId])
  @@index([jahr])
}

// ─── ZERTIFIZIERUNGS-TRACKER ──────────────────────────────────────────────────

model Zertifizierung {
  id               Int       @id @default(autoincrement())
  kundeId          Int
  typ              String    // "QS"|"GlobalGAP"|"Bio/Öko"|"Cross-Compliance"|"Ernte-Plus"|"DLG"|"Sonstige"
  nummer           String?   // Zertifikatsnummer
  ausstellerOrg    String?   // z.B. "QS GmbH", "LUFA"
  ausstellungsdatum DateTime?
  ablaufdatum      DateTime?
  status           String    @default("aktiv") // aktiv | abgelaufen | gesperrt
  belegpfad        String?
  belegname        String?
  notiz            String?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  kunde            Kunde     @relation(fields: [kundeId], references: [id], onDelete: Cascade)

  @@index([kundeId])
  @@index([ablaufdatum])
  @@index([typ])
}

// ─── PEGELSTÄNDE (WSV Pegelonline) ───────────────────────────────────────────

model PegelstandCache {
  id           Int      @id @default(autoincrement())
  stationUuid  String   @unique
  stationKurz  String
  stationLang  String
  gewaesser    String
  lat          Float?
  lng          Float?
  einheit      String   @default("cm")
  wert         Float?
  trend        Int?     // -1 fallend, 0 gleichbleibend, 1 steigend
  messung      DateTime?
  fetchedAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([stationUuid])
}

// ─── MQTT-AUTOMATISIERUNG ─────────────────────────────────────────────────────

model MqttRegel {
  id           Int      @id @default(autoincrement())
  name         String
  source       String   @default("")  // z.B. MQTT-Broker-URL oder Quell-Label
  topicPattern String
  modus        String   @default("ki")  // "ki" | "direkt"
  aktion       String   // "lieferung" | "wareneingang" | "benachrichtigung"
  aktiv        Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([aktiv])
}
