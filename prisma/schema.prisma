generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
}

// ─── KUNDE ────────────────────────────────────────────────────────────────────

model Kunde {
  id               Int      @id @default(autoincrement())
  name             String
  firma            String?
  kategorie        String   @default("Sonstige")
  verantwortlicher String?  // frei gewählt aus Mitarbeiterliste
  betriebsnummer   String?  // z.B. aus AFIG/InVeKoS
  flaeche          Float?   // ha, manuell erfasst
  strasse          String?
  plz              String?
  ort              String?
  land             String   @default("Deutschland")
  lat              Float?
  lng              Float?
  notizen          String?
  tags             String   @default("[]")  // JSON array of tag strings
  ustIdNr          String?  // USt-Identifikationsnummer (für ZUGFeRD E-Rechnung)
  aktiv            Boolean  @default(true)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  kontakte         KundeKontakt[]
  bedarfe          KundeBedarf[]
  artikelPreise    KundeArtikelPreis[]
  lieferungen      Lieferung[]
  mengenrabatte    Mengenrabatt[]
  sammelrechnungen Sammelrechnung[]
  aktivitaeten     KundeAktivitaet[]
  antragDaten      AntragEmpfaenger[]
  kundeNotizen     KundeNotiz[]
  angebote         Angebot[]
  schlaegte        KundeSchlag[]
  aufgaben         Aufgabe[]
  gutschriften     Gutschrift[]
  bestellpositionen Bestellposition[]
  driveOrdnerId    String?  // Google Drive Folder ID

  @@index([aktiv])
  @@index([kategorie])
  @@index([name])
}

model KundeKontakt {
  id       Int     @id @default(autoincrement())
  kundeId  Int
  typ      String  // telefon | mobil | email | fax
  wert     String
  label    String? // z.B. "Büro"
  vorname  String?
  nachname String?

  kunde Kunde @relation(fields: [kundeId], references: [id], onDelete: Cascade)
}

// ─── NOTIZEN ─────────────────────────────────────────────────────────────────

model KundeNotiz {
  id       Int      @id @default(autoincrement())
  kundeId  Int
  kunde    Kunde    @relation(fields: [kundeId], references: [id], onDelete: Cascade)
  text     String
  thema    String?  // e.g. "Wichtig", "Offener Punkt", "Erledigt", "Info"
  erstellt DateTime @default(now())

  @@index([kundeId])
}

// ─── CRM ──────────────────────────────────────────────────────────────────────

model KundeAktivitaet {
  id        Int      @id @default(autoincrement())
  kundeId   Int
  typ       String   // besuch | anruf | email | notiz | aufgabe
  betreff   String
  inhalt    String?
  datum     DateTime @default(now())
  erledigt  Boolean  @default(false)
  faelligAm DateTime?
  createdAt DateTime @default(now())

  kunde Kunde @relation(fields: [kundeId], references: [id], onDelete: Cascade)

  @@index([kundeId])
  @@index([datum])
  @@index([faelligAm])
}

// ─── LIEFERANT ────────────────────────────────────────────────────────────────

model Lieferant {
  id              Int      @id @default(autoincrement())
  name            String
  ansprechpartner String?
  email           String?
  telefon         String?
  strasse         String?
  plz             String?
  ort             String?
  notizen         String?
  aktiv           Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  artikelZuordnungen ArtikelLieferant[]
  wareneingaenge     Wareneingang[]
  bestellpositionen  Bestellposition[]
  ausgaben           Ausgabe[]
}

// ─── ARTIKEL ──────────────────────────────────────────────────────────────────

model Artikel {
  id               Int      @id @default(autoincrement())
  artikelnummer    String   @unique
  name             String
  kategorie        String   // Futter | Duenger | Saatgut
  einheit          String   @default("kg") // kg | t | Sack | Liter | Stück
  beschreibung     String?
  standardpreis    Float    @default(0)
  preisStand       DateTime? // Datum, von wann der aktuelle Preis ist
  mwstSatz         Float    @default(19) // 0 | 7 | 19
  mindestbestand   Float    @default(0)
  aktuellerBestand Float    @default(0)
  aktiv            Boolean  @default(true)
  lagerort         String?  // optional: storage location label
  liefergroesse    String?  // Liefergröße Freitext (z.B. "25 kg Sack", "Big Bag 600 kg")
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  inhaltsstoffe    ArtikelInhaltsstoff[]
  lieferanten      ArtikelLieferant[]
  kundePreise      KundeArtikelPreis[]
  preisHistorie    ArtikelPreisHistorie[]
  bedarfe          KundeBedarf[]
  lieferpositionen Lieferposition[]
  angebotPositionen AngebotPosition[]
  lagerbewegungen  Lagerbewegung[]
  wareineingangPos WareineingangPosition[]
  dokumente        ArtikelDokument[]
  mengenrabatte    Mengenrabatt[]
  inventurPositionen InventurPosition[]
  gutschriftPositionen GutschriftPosition[]
  bestellpositionen Bestellposition[]
  driveOrdnerId    String?  // Google Drive Folder ID

  @@index([aktiv])
  @@index([kategorie])
  @@index([name])
}

model ArtikelInhaltsstoff {
  id        Int    @id @default(autoincrement())
  artikelId Int
  name      String   // z.B. "Schwefel", "Rohprotein", "Bor"
  menge     Float?   // z.B. 90
  einheit   String?  // z.B. "%", "mg/kg", "g/l"

  artikel Artikel @relation(fields: [artikelId], references: [id], onDelete: Cascade)

  @@index([artikelId])
  @@index([name])
}

model ArtikelDokument {
  id          Int      @id @default(autoincrement())
  artikelId   Int
  name        String
  dateiname   String   // original filename
  pfad        String   // stored path under /uploads/artikel/
  typ         String?  // MIME type
  groesse     Int?     // bytes
  notiz       String?
  createdAt   DateTime @default(now())

  artikel Artikel @relation(fields: [artikelId], references: [id], onDelete: Cascade)
}

model ArtikelLieferant {
  id                  Int      @id @default(autoincrement())
  artikelId           Int
  lieferantId         Int
  lieferantenArtNr    String?
  einkaufspreis       Float    @default(0)
  mindestbestellmenge Float    @default(0)
  lieferzeitTage      Int      @default(3)
  bevorzugt           Boolean  @default(false)
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  artikel   Artikel   @relation(fields: [artikelId], references: [id], onDelete: Cascade)
  lieferant Lieferant @relation(fields: [lieferantId], references: [id], onDelete: Cascade)

  @@unique([artikelId, lieferantId])
}

// Preishistorie: jede Änderung am Standardpreis wird versioniert
model ArtikelPreisHistorie {
  id          Int      @id @default(autoincrement())
  artikelId   Int
  alterPreis  Float
  neuerPreis  Float
  geaendertAm DateTime @default(now())
  notiz       String?

  artikel Artikel @relation(fields: [artikelId], references: [id], onDelete: Cascade)
}

// ─── PREISE & KONDITIONEN ─────────────────────────────────────────────────────

model KundeArtikelPreis {
  id        Int      @id @default(autoincrement())
  kundeId   Int
  artikelId Int
  preis     Float
  rabatt    Float    @default(0) // Prozent
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  kunde   Kunde   @relation(fields: [kundeId], references: [id], onDelete: Cascade)
  artikel Artikel @relation(fields: [artikelId], references: [id], onDelete: Cascade)

  @@unique([kundeId, artikelId])
}

// ─── BEDARF (wiederkehrende Lieferungen) ──────────────────────────────────────

model KundeBedarf {
  id            Int      @id @default(autoincrement())
  kundeId       Int
  artikelId     Int
  menge         Float
  intervallTage Int      @default(30)
  notiz         String?
  aktiv         Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  kunde   Kunde   @relation(fields: [kundeId], references: [id], onDelete: Cascade)
  artikel Artikel @relation(fields: [artikelId], references: [id], onDelete: Cascade)

  @@unique([kundeId, artikelId])
}

// ─── LIEFERUNG ────────────────────────────────────────────────────────────────

model Lieferung {
  id               Int      @id @default(autoincrement())
  kundeId          Int
  datum            DateTime @default(now())
  lieferDatum      DateTime? // tatsächliches Lieferdatum (falls abweichend von datum) – erscheint auf der Rechnung
  status           String   @default("geplant") // geplant | geliefert | storniert
  stornoBegründung String?
  notiz            String?
  rechnungNr       String?  // gesetzt wenn Rechnung erstellt wurde
  rechnungDatum    DateTime?
  bezahltAm        DateTime?
  zahlungsziel     Int?      @default(30)  // Tage
  wiederkehrend    Boolean  @default(false) // wurde automatisch angelegt
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  kunde             Kunde            @relation(fields: [kundeId], references: [id])
  positionen        Lieferposition[]
  lagerbewegungen   Lagerbewegung[]
  sammelrechnung    Sammelrechnung?  @relation(fields: [sammelrechnungId], references: [id])
  sammelrechnungId  Int?
  gutschriften      Gutschrift[]
  bestellpositionen Bestellposition[]

  @@index([kundeId])
  @@index([status])
  @@index([datum])
  @@index([status, datum])
}

model Lieferposition {
  id            Int     @id @default(autoincrement())
  lieferungId   Int
  artikelId     Int
  menge         Float
  verkaufspreis Float
  einkaufspreis Float   @default(0)
  chargeNr      String? // Chargen-/Losnummer (gesetzlich für Saatgut)
  rabattProzent Float   @default(0) // Mengenrabatt der angewendet wurde
  notiz         String? // Auftragsnummer / interne Notiz zur Position

  lieferung Lieferung @relation(fields: [lieferungId], references: [id], onDelete: Cascade)
  artikel   Artikel   @relation(fields: [artikelId], references: [id])

  @@index([lieferungId])
  @@index([artikelId])
}

// ─── WARENEINGANG ─────────────────────────────────────────────────────────────

model Wareneingang {
  id          Int      @id @default(autoincrement())
  lieferantId Int
  datum       DateTime @default(now())
  notiz       String?
  createdAt   DateTime @default(now())

  lieferant       Lieferant              @relation(fields: [lieferantId], references: [id])
  positionen      WareineingangPosition[]
  lagerbewegungen Lagerbewegung[]
}

model WareineingangPosition {
  id             Int   @id @default(autoincrement())
  wareneingangId Int
  artikelId      Int
  menge          Float
  einkaufspreis  Float

  wareneingang Wareneingang @relation(fields: [wareneingangId], references: [id], onDelete: Cascade)
  artikel      Artikel      @relation(fields: [artikelId], references: [id])

  @@index([wareneingangId])
  @@index([artikelId])
}

// ─── LAGERBEWEGUNG ────────────────────────────────────────────────────────────

model Lagerbewegung {
  id             Int      @id @default(autoincrement())
  artikelId      Int
  typ            String   // eingang | ausgang | korrektur | UMBUCHUNG
  menge          Float    // positiv = Zugang, negativ = Abgang
  bestandNach    Float
  datum          DateTime @default(now())
  notiz          String?
  lieferungId    Int?
  wareneingangId Int?
  lagerortVon    String?  // source location (for Umbuchung)
  lagerortNach   String?  // target location (for Umbuchung)

  artikel      Artikel       @relation(fields: [artikelId], references: [id])
  lieferung    Lieferung?    @relation(fields: [lieferungId], references: [id])
  wareneingang Wareneingang? @relation(fields: [wareneingangId], references: [id])

  @@index([artikelId])
  @@index([datum])
  @@index([artikelId, datum])
}

// ─── MENGENRABATTE ────────────────────────────────────────────────────────────

model Mengenrabatt {
  id            Int      @id @default(autoincrement())
  kundeId       Int?     // null = gilt für alle Kunden
  artikelId     Int?     // null = gilt für alle Artikel der Kategorie
  kategorie     String?  // alternativ zu artikelId: gilt für ganze Kategorie
  vonMenge      Float    // ab dieser Menge gilt der Rabatt
  rabattProzent Float    // Rabatt in %
  aktiv         Boolean  @default(true)
  createdAt     DateTime @default(now())

  kunde   Kunde?   @relation(fields: [kundeId], references: [id], onDelete: Cascade)
  artikel Artikel? @relation(fields: [artikelId], references: [id], onDelete: Cascade)
}

// ─── SAMMELRECHNUNG ───────────────────────────────────────────────────────────

model Sammelrechnung {
  id           Int      @id @default(autoincrement())
  kundeId      Int
  rechnungNr   String?
  rechnungDatum DateTime?
  bezahltAm   DateTime?
  zahlungsziel Int      @default(30)
  notiz        String?
  createdAt    DateTime @default(now())

  kunde       Kunde       @relation(fields: [kundeId], references: [id])
  lieferungen Lieferung[]
}

// ─── BESTELLLISTE (Lieferanten-Bestellungen) ─────────────────────────────────

model Bestellposition {
  id            Int       @id @default(autoincrement())
  lieferantId   Int
  artikelId     Int
  kundeId       Int?      // Rückverfolgbarkeit: welcher Kunde
  lieferungId   Int?      // Rückverfolgbarkeit: welche Lieferung
  angebotId     Int?      // Rückverfolgbarkeit: welches Angebot
  menge         Float
  einheit       String    @default("kg")
  einkaufspreis Float     @default(0)
  status        String    @default("offen") // offen | bestellt | geliefert | storniert
  bestelltAm    DateTime?
  geliefertAm   DateTime?
  notiz         String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  lieferant Lieferant  @relation(fields: [lieferantId], references: [id])
  artikel   Artikel    @relation(fields: [artikelId], references: [id])
  kunde     Kunde?     @relation(fields: [kundeId], references: [id])
  lieferung Lieferung? @relation(fields: [lieferungId], references: [id])

  @@index([lieferantId])
  @@index([artikelId])
  @@index([status])
  @@index([lieferungId])
}

// ─── INVENTUR ────────────────────────────────────────────────────────────────

model Inventur {
  id          Int                @id @default(autoincrement())
  datum       DateTime           @default(now())
  status      String             @default("OFFEN") // OFFEN | ABGESCHLOSSEN
  bezeichnung String?
  positionen  InventurPosition[]

  @@index([status])
}

model InventurPosition {
  id          Int      @id @default(autoincrement())
  inventurId  Int
  inventur    Inventur @relation(fields: [inventurId], references: [id], onDelete: Cascade)
  artikelId   Int
  artikel     Artikel  @relation(fields: [artikelId], references: [id])
  sollBestand Float    // snapshot of bestand at time of inventur
  istBestand  Float?   // counted value
  differenz   Float?   // computed: istBestand - sollBestand
  bemerkung   String?

  @@index([inventurId])
  @@index([artikelId])
}

// ─── SYSTEM: Rechnungsnummer-Zähler ──────────────────────────────────────────

model Einstellung {
  key   String @id
  value String
}

// ─── OPEN DATA: Marktpreise (Eurostat) ───────────────────────────────────────

model MarktpreisCache {
  id          Int      @id @default(autoincrement())
  dataset     String   // "apri_pi15_inq" (quartalsweise) oder "apri_pi15_ina" (jährlich)
  produktCode String   // z.B. "206000" (Futtermittel)
  produktName String   // z.B. "Futtermittel"
  zeitraum    String   // z.B. "2024-Q3" oder "2024"
  indexWert   Float    // Indexwert (2015 = 100)
  einheit     String   @default("I15")
  land        String   @default("DE")
  abgerufenAm DateTime @default(now())
  createdAt   DateTime @default(now())

  @@unique([dataset, produktCode, zeitraum, land])
}

// ─── OPEN DATA: Agrarflächen (Overpass / OSM) ────────────────────────────────

model AgrarflaechenCache {
  id           Int      @id @default(autoincrement())
  lat          Float
  lng          Float
  radius       Int      // Meter
  flaecheHa    Float    // Gesamtfläche in Hektar
  polygonCount Int      // Anzahl Polygone
  geojson      String   // GeoJSON FeatureCollection
  abgerufenAm  DateTime @default(now())
  createdAt    DateTime @default(now())

  @@unique([lat, lng, radius])
}

// ─── AGRARANTRÄGE (AFIG / agrarzahlungen.de) ──────────────────────────────────

model AntragEmpfaenger {
  id                        Int      @id @default(autoincrement())
  haushaltsjahr             Int
  name                      String   // Name des Begünstigten
  plz                       String?
  gemeinde                  String?
  land                      String?
  steuerNr                  String?  // Steuerliches Identifikationsmerkmal
  egflGesamt                Float    @default(0)  // EGFL-Gesamtbetrag für diesen Begünstigten (Spalte 12)
  elerGesamt                Float    @default(0)  // ELER-Gesamtbetrag EU-Mittel (Spalte 14)
  nationalKofiGesamt        Float    @default(0)  // National kofinanzierter Gesamtbetrag (Spalte 16)
  elerUndKofiGesamt         Float    @default(0)  // ELER + national Kofi (Spalte 17)
  gesamtBetrag              Float    @default(0)  // EU-Betrag + Kofi gesamt (Spalte 18)
  massnahmen                String?  // JSON: [{code, ziel, egfl, eler, nationalKofi, anfang, ende}]
  mutterunternehmen         String?
  importiertAm              DateTime @default(now())

  kundeId           Int?
  kunde             Kunde?   @relation(fields: [kundeId], references: [id], onDelete: SetNull)

  @@index([name])
  @@index([plz])
  @@index([gemeinde])
  @@index([haushaltsjahr])
  @@index([kundeId])
}

// ─── AUFGABEN / TODO ──────────────────────────────────────────────────────────

model Aufgabe {
  id           Int       @id @default(autoincrement())
  betreff      String
  beschreibung String?
  faelligAm    DateTime?
  erledigt     Boolean   @default(false)
  erledigtAm   DateTime?
  prioritaet   String    @default("normal")  // niedrig | normal | hoch | kritisch
  tags         String    @default("[]")       // JSON array of strings
  typ          String    @default("aufgabe")  // aufgabe | anruf | besuch | email
  kundeId      Int?
  erstellt     DateTime  @default(now())
  aktualisiert DateTime  @updatedAt

  kunde        Kunde?    @relation(fields: [kundeId], references: [id], onDelete: SetNull)

  @@index([kundeId])
  @@index([erledigt])
  @@index([faelligAm])
  @@index([erledigt, faelligAm])
  @@index([kundeId, erledigt])
}

// ─── ANGEBOTSWESEN ────────────────────────────────────────────────────────────

model Angebot {
  id          Int      @id @default(autoincrement())
  nummer      String   @unique          // z.B. AN-2026-0001
  datum       DateTime @default(now())
  gueltigBis  DateTime?
  status      String   @default("OFFEN") // OFFEN | ANGENOMMEN | ABGELEHNT | ABGELAUFEN
  kundeId     Int
  notiz       String?
  erstellt    DateTime @default(now())
  aktualisiert DateTime @updatedAt

  kunde       Kunde            @relation(fields: [kundeId], references: [id], onDelete: Cascade)
  positionen  AngebotPosition[]

  @@index([kundeId])
  @@index([status])
  @@index([datum])
}

model AngebotPosition {
  id         Int    @id @default(autoincrement())
  angebotId  Int
  artikelId  Int
  menge      Float
  preis      Float  // Angebotspreis (netto)
  rabatt     Float  @default(0)
  einheit    String @default("kg")
  notiz      String?

  angebot    Angebot @relation(fields: [angebotId], references: [id], onDelete: Cascade)
  artikel    Artikel @relation(fields: [artikelId], references: [id])

  @@index([angebotId])
  @@index([artikelId])
}

// ─── GUTSCHRIFTEN / RETOUREN ──────────────────────────────────────────────────

model Gutschrift {
  id          Int      @id @default(autoincrement())
  nummer      String   @unique  // GS-YYYY-NNNN
  kundeId     Int
  lieferungId Int?     // optional reference to original delivery
  datum       DateTime @default(now())
  grund       String   // Reklamation | Retoure | Preiskorrektur | Sonstiges
  notiz       String?
  status      String   @default("OFFEN")  // OFFEN | VERBUCHT | STORNIERT
  createdAt   DateTime @default(now())

  kunde       Kunde              @relation(fields: [kundeId], references: [id])
  lieferung   Lieferung?         @relation(fields: [lieferungId], references: [id])
  positionen  GutschriftPosition[]

  @@index([kundeId])
  @@index([datum])
}

model GutschriftPosition {
  id           Int     @id @default(autoincrement())
  gutschriftId Int
  artikelId    Int
  menge        Float
  preis        Float   // unit price for credit
  ruecknahme   Boolean @default(false)  // true = return to stock

  gutschrift   Gutschrift @relation(fields: [gutschriftId], references: [id], onDelete: Cascade)
  artikel      Artikel    @relation(fields: [artikelId], references: [id])
}

// ─── AUDIT-LOG ────────────────────────────────────────────────────────────────

model AuditLog {
  id           Int      @id @default(autoincrement())
  zeitpunkt    DateTime @default(now())
  entitaet     String   // "Kunde" | "Artikel" | "Lieferung" | "Lager" | etc.
  entitaetId   Int      // ID des betroffenen Datensatzes
  aktion       String   // "erstellt" | "geaendert" | "geloescht"
  feld         String?  // welches Feld geändert wurde (null bei erstellt/geloescht)
  alterWert    String?  // alter Wert (als String)
  neuerWert    String?  // neuer Wert (als String)
  beschreibung String?  // lesbare Beschreibung

  @@index([entitaet, entitaetId])
  @@index([zeitpunkt])
}

// ─── SCHLAGKARTEI ─────────────────────────────────────────────────────────────

model KundeSchlag {
  id         Int      @id @default(autoincrement())
  kundeId    Int
  name       String                          // Schlagname / Feldname
  flaeche    Float                           // ha
  fruchtart  String?                         // Weizen, Raps, Gerste …
  sorte      String?                         // Sortenname
  vorfrucht  String?
  aussaatJahr Int?
  aussaatMenge Float?                        // kg/ha
  notiz      String?
  erstellt   DateTime @default(now())

  kunde      Kunde @relation(fields: [kundeId], references: [id], onDelete: Cascade)

  @@index([kundeId])
}

// ─── AUSGABENBUCH (Betriebsausgaben / Eingangsrechnungen) ─────────────────────

model Ausgabe {
  id           Int       @id @default(autoincrement())
  datum        DateTime  @default(now())
  belegNr      String?   // Eingangsrechnungsnummer des Lieferanten
  beschreibung String
  betragNetto  Float
  mwstSatz     Float     @default(19) // 0 | 7 | 19
  kategorie    String    @default("Sonstige")
  // Kategorien: Wareneinkauf | Betriebsbedarf | Fahrtkosten | Bürobedarf |
  //             Telefon/Internet | Versicherung | Miete | Sonstige
  lieferantId  Int?
  lieferant    Lieferant? @relation(fields: [lieferantId], references: [id], onDelete: SetNull)
  bezahltAm      DateTime?
  notiz          String?
  belegPfad      String?   // Relativer Pfad zur hochgeladenen Belegdatei (z.B. /uploads/belege/2026/20260403_42_RE-2026-1234.jpg)
  belegDateiname String?   // Originaler Dateiname des Belegs
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  @@index([datum])
  @@index([lieferantId])
  @@index([kategorie])
}

// ─── BANKABGLEICH (Kontoauszug-Import & Zahlungszuordnung) ───────────────────

model Kontoumsatz {
  id               Int       @id @default(autoincrement())
  kontoBezeichnung String?   // z.B. "Geschäftskonto Sparkasse"
  buchungsdatum    DateTime
  wertstellung     DateTime?
  betrag           Float     // positiv = Eingang, negativ = Ausgang
  waehrung         String    @default("EUR")
  verwendungszweck String
  gegenkonto       String?   // IBAN der Gegenpartei
  gegenkontoName   String?   // Name der Gegenpartei
  saldo            Float?
  zugeordnet       Boolean   @default(false)
  lieferungId      Int?
  sammelrechnungId Int?
  ausgabeId        Int?      // Zuordnung zu Betriebsausgabe
  importDatum      DateTime  @default(now())
  importDatei      String?   // Name der Importdatei (für Rückverfolgung)

  @@index([buchungsdatum])
  @@index([zugeordnet])
  @@index([betrag])
}

// ─── KI-NUTZUNG (AI Usage Statistics) ────────────────────────────────────────

model KiNutzung {
  id          Int      @id @default(autoincrement())
  zeitpunkt   DateTime @default(now())
  provider    String                           // "openai" | "anthropic"
  modell      String                           // "gpt-4o" | "claude-sonnet-4-20250514" etc.
  feature     String                           // "wareneingang" | "lieferung" | "crm"
  tokensIn    Int
  tokensOut   Int
  kostenCent  Int      @default(0)
  erfolgreich Boolean  @default(true)
  fehler      String?

  @@index([zeitpunkt, feature])
}
